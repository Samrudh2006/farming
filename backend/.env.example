# ─── ISIN Backend Environment Variables ───────────────────
# Copy this file to .env and fill in the values.

# Database
DATABASE_URL=postgresql+asyncpg://isin_user:isin_password@localhost:5432/isin_db

# Auth / JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI (for AI evaluation)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Judge0 (code execution sandbox)
JUDGE0_URL=http://localhost:2358

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limits
MAX_SUBMISSIONS_PER_USER_PER_DAY=10
MAX_OPENAI_COST_PER_DAY_USD=5.0

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
